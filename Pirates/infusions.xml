<?xml version="1.0" encoding="utf-8" ?>
<elements>
	<info>
		<name>Infusions</name>
		<description>Infusions from the Pirates campaign</description>
		<update version="0.0.1">
			<file name="infusions.xml" url="https://raw.githubusercontent.com/TFritz28/dnd-homebrew/master/Pirates/infusions.xml" />
		</update>
	</info>
	
	<!-- Infused Shield -->
	<element name="Shield Infusion" type="Feat" source="Pirates" id="ID_PIRATES_FEATS_SHIELD_INFUSION">
		<description></description>
		<sheet display="false" />
		<rules>
			<!--<select type="Feat Feature" name="Passive Infusion (Infused Shield)" supports="Passive Aether Infusion" /> -->
			<select type="Feat Feature" name="Active Infusion (Infused Shield)" supports="Active Infusion" />
			<select type="Feat Feature" name="Artificer Infusion (Infused Shield)" supports="Artificer Infusion Shield" />
		</rules>
	</element>
	
	<!-- Infused Armor -->	
	<element name="Armor Infusion" type="Feat" source="Pirates" id="ID_PIRATES_FEATS_ARMOR_INFUSION">
		<description></description>
		<sheet display="false" />
		<rules>
			<grant type="Grants" id="ID_GRANTS_INFUSED_ARMOR_EQUIPPED" />
			<select type="Feat Feature" name="Passive Infusion (Infused Armor)" supports="Passive Aether Infusion" />
			<select type="Feat Feature" name="Active Infusion (Infused Armor)" supports="Active Infusion" />
			<select type="Feat Feature" name="Artificer Infusion (Infused Armor)" supports="Artificer Infusion Armor" />
		</rules>
	</element>
	
	<!--Artificer Infusions -->
	<element name="Enhanced Defense" type="Feat Feature" source="Pirates" id="ID_PIRATES_FEAT_FEATURE_ENHANCED_DEFENSE" >
		<supports>Artificer Infusion Armor, Artificer Infusion Shield</supports>
		<description></description>
		<sheet display="false"/>
		<rules>
			<stat name="ac:misc" value="1" requirements="ID_GRANTS_INFUSED_ARMOR_EQUIPPED" />
			<stat name="ac:misc" value="1" level="10" requirements="ID_GRANTS_INFUSED_ARMOR_EQUIPPED" />
		</rules>
	</element>
	
	<element name="Resistant Armor" type="Feat Feature" source="Pirates" id="ID_PIRATES_FEAT_FEATURE_RESISTANT_ARMOR" >
		<supports>Artificer Infusion Armor</supports>
		<description></description>
		<sheet display="false"/>
		<rules>
			<grant type="Feat" id="ID_PIRATES_FEATS_ARMOR_OF_RESISTANCE" />
		</rules>
	</element>
	<element name="Resistant Armor" type="Feat" source="Pirates" id="ID_PIRATES_FEATS_ARMOR_OF_RESISTANCE">
		<description></description>
		<sheet>
			<description>
			While having this armor equipped you gain resistance to the following damage types:
			</description>
		</sheet>
		<rules>
			<select name="Resistance (Resistant Armor)" type="Feat Feature" supports="Armor of Resistance"/>
			<stat name="attunement:current" value="1" bonus="enhancement" />
		</rules>
	</element>
	<element name="Radiant" type="Feat Feature" source="Pirates" id="ID_PIRATES_FEAT_FEATURE_RADIANT_RESISTANCE" >
		<supports>Armor of Resistance</supports>
		<description></description>
		<rules>
			<grant type="Condition" id="ID_INTERNAL_CONDITION_DAMAGE_RESISTANCE_RADIANT" requirements="ID_GRANTS_INFUSED_ARMOR_EQUIPPED"/>
		</rules>
	</element>
	<element name="Lightning" type="Feat Feature" source="Pirates" id="ID_PIRATES_FEAT_FEATURE_LIGHTNING_RESISTANCE" >

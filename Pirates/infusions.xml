	<!-- Passive Infusions -->
	<element name="Aether Reinforcement" type="Feat Feature" source="Pirates" id="ID_PIRATES_GRANTS_AETHER_REINFORCEMENT" >
		<supports>Passive Aether Infusion</supports>
		<description></description>
		<sheet display="false"/>
		<rules>
			<stat name="ac:misc" value="1" requirements="ID_GRANTS_INFUSED_ARMOR_EQUIPPED"/>
		</rules>
	</element>
	<element name="Dimensional Cushioning" type="Feat Feature" source="Pirates" id="ID_PIRATES_FEAT_FEATURE_DIMENSIONAL_CUSHIONING" >
		<supports>Passive Aether Infusion</supports>
		<description>You gain Resistance to falling damage and advantage on DEX saves to avoid area effects (explosions, traps, etc.).</description>
		<sheet>
			<description>
			You gain Resistance to falling damage and advantage on DEX saves to avoid area effects (explosions, traps, etc.).
			</description>
		</sheet>
	</element>
	<element name="Aetheric Vitality" type="Feat Feature" source="Pirates" id="ID_PIRATES_FEAT_FEATURE_AETHERIC_VITALITY" >
		<supports>Passive Aether Infusion</supports>
		<description>While wearing this armor, you recover +1 extra HP whenever you roll Hit Dice during a Short Rest.</description>
		<sheet>
			<description>
			While wearing this armor, you recover +1 extra HP whenever you roll Hit Dice during a Short Rest.
			</description>
		</sheet>
	</element>
	
	<!-- Active Infusions -->
	<element name="Phase Barrier Armor" type="Feat Feature" source="Pirates" id="ID_PIRATES_FEAT_FEATURE_PHASE_BARRIER_ARMOR">
		<supports>Active Infusion</supports>
		<description>As a Reaction to taking damage, reduce that damage by 1d8, as your form partially phases out of sync with the world for an instant. You can use this reaction once per Short Rest.</description>
		<sheet action="Reaction" usage="1/Short Rest">
			<description>
				As a Reaction to taking damage, reduce that damage by 1d8, as your form partially phases out of sync with the world for an instant. You can use this reaction once per Short Rest.
			</description>
		</sheet>
	</element>
	<element name="Aether Step" type="Feat Feature" source="Pirates" id="ID_PIRATES_FEAT_FEATURE_AETHER_STEP">
		<supports>Active Infusion</supports>
		<description>Once per Short Rest, as a Bonus Action, you can teleport up to 15 ft to a space you can see, leaving behind a faint arcane shimmer.</description>
		<sheet action="Bonus Action" usage="1/Short Rest">
			<description>
				As a bonus action, you can teleport up to 15 ft to a space you can see.
			</description>
		</sheet>
	</element>
	<element name="Pulse Discharge" type="Feat Feature" source="Pirates" id="ID_PIRATES_FEAT_FEATURE_PULSE_DISCHARGE">
		<supports>Active Infusion</supports>
		<description>When you are hit by a melee attack, you can trigger an Aether pulse — the attacker must succeed a DC 13 STR save or be pushed 10 ft away.</description>
		<sheet action="Reaction" usage="1/Short Rest">
			<description>
				When you are hit by a melee attack, you can trigger an Aether pulse — the attacker must succeed a DC 13 STR save or be pushed 10 ft away.
			</description>
		</sheet>
	</element>
	<element name="Crystal Shield" type="Feat Feature" source="Pirates" id="ID_PIRATES_FEAT_FEATURE_CRYSTAL_SHIELD">
		<supports>Active Infusion</supports>
		<description>You can cast the Shield spell once per Short Rest without expending a spell slot. For each additional item that is infused with this effect, you can cast Shield one more time per Short Rest.</description>
		<sheet action="Reaction" usage="{{crystal shield:uses}}/Short Rest">
			<description>
				You can cast the Shield spell without expending a spell slot.
			</description>
		</sheet>
		<rules>
			<grant type="Spell" id="ID_PHB_SPELL_SHIELD" />
			<stat name="crystal shield:uses" value="1" />
		</rules>
			
	</element>
	
	<element name="Crystal Shield" type="Feat Feature" source="Pirates" id="ID_PIRATES_FEAT_FEATURE_CRYSTAL_SHIELD_DUAL">
		<supports>Active Infusion</supports>
		<requirements>ID_PIRATES_FEAT_FEATURE_CRYSTAL_SHIELD</requirements>
		<description>You can cast the Shield spell without expending a spell slot.</description>
		<sheet display="false" />
		<rules>
			<stat name="crystal shield:uses" value="1" />
		</rules>
			
	</element>
</elements>